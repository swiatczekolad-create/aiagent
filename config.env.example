# ========================================
# Orchestrator — Konfiguracja
# Skopiuj do config.env i uzupełnij wartości
# ========================================

# === WYMAGANE ===
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHI...
TELEGRAM_CHAT_ID=123456789

# === MODEL REVIEWERA ===
# Model używany do oceny kroków
REVIEWER_MODEL=claude-sonnet-4-6

# === LIMITY ===
# Max prób poprawy jednego kroku
MAX_REVIEW_ITERATIONS=3

# Timeout Claude Code na jeden krok (sekundy)
STEP_TIMEOUT=300

# Timeout na decyzję użytkownika przez Telegram (sekundy)
DECISION_TIMEOUT=7200

# === TRYB PRACY ===
# true = czekaj na potwierdzenie usera po każdym kroku
# false = leć automatycznie (reviewer decyduje)
INTERACTIVE_MODE=true
